__pycache__/
*.py[cod]

# Tool caches — regenerated on demand, never committed.
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Seed-grown project state is runtime output; the engine recreates it.
factory_state/projects/

# Application workbenches are runtime, created by promote; not committed.
apps/*
!apps/.gitkeep

# Per-run autopilot trace/summary logs (9D.7); runtime, never committed.
logs/
